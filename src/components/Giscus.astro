---
// Renders the giscus comment widget, backed by GitHub Discussions on freyja-org/discussion.
//
// Setup steps before this will work:
// 1. Create the freyja-org/discussion repo and enable Discussions on it (Settings > Features).
// 2. Install the giscus app on that repo: https://github.com/apps/giscus
// 3. Run the config generator at https://giscus.app, pointing it at freyja-org/discussion,
//    and copy the data-repo-id / data-category / data-category-id values it outputs below.
const repo = 'freyja-org/discussion';
const repoId = 'TODO_REPO_ID';
const category = 'General';
const categoryId = 'TODO_CATEGORY_ID';
---

<section id="giscus-comments">
	<script
		src="https://giscus.app/client.js"
		data-repo={repo}
		data-repo-id={repoId}
		data-category={category}
		data-category-id={categoryId}
		data-mapping="pathname"
		data-strict="0"
		data-reactions-enabled="1"
		data-emit-metadata="0"
		data-input-position="top"
		data-theme="preferred_color_scheme"
		data-lang="en"
		crossorigin="anonymous"
		async
	></script>
</section>
