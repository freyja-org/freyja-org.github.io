---
import Base from '../layouts/Base.astro';
import { getRecentDiscussions, formatRelativeTime, CATEGORY_META } from '../lib/discussions';

const discussions = await getRecentDiscussions();
const defaultMeta = { color: '#6b7280', emoji: '💬' };
---

<Base title="Discussions">
	<h1>Discussions</h1>
	<p>
		All community discussion happens on GitHub Discussions in{' '}
		<a href="https://github.com/freyja-org/discussion/discussions" target="_blank" rel="noopener noreferrer">
			freyja-org/discussion
		</a>.
	</p>

	<h2>Recent discussions</h2>
	{
		discussions.length === 0 ? (
			<p>
				Couldn't load recent discussions right now — browse them directly on{' '}
				<a
					href="https://github.com/freyja-org/discussion/discussions"
					target="_blank"
					rel="noopener noreferrer"
				>
					GitHub
				</a>.
			</p>
		) : (
			<ul class="discussion-list">
				{discussions.map((d) => (
					<li>
						<a href={d.url} target="_blank" rel="noopener noreferrer" class="discussion-title">
							{d.title}
						</a>
						{d.bodyPreview && <p class="discussion-preview">{d.bodyPreview}</p>}
						<div class="discussion-meta">
							<span
								class="category-pill"
								style={`--pill-color: ${(CATEGORY_META[d.categoryName] ?? defaultMeta).color}`}
							>
								{(CATEGORY_META[d.categoryName] ?? defaultMeta).emoji} {d.categoryName}
							</span>
							<span class="dot">·</span>
							<span>{formatRelativeTime(d.updatedAt)}</span>
							<span class="dot">·</span>
							<span>{d.commentCount} {d.commentCount === 1 ? 'comment' : 'comments'}</span>
						</div>
					</li>
				))}
			</ul>
		)
	}

	<p class="discussion-links">
		<a
			href="https://github.com/freyja-org/discussion/discussions"
			target="_blank"
			rel="noopener noreferrer"
		>
			Browse all discussions &rarr;
		</a>
		<a
			href="https://github.com/freyja-org/discussion/discussions/new/choose"
			target="_blank"
			rel="noopener noreferrer"
		>
			Start a new discussion &rarr;
		</a>
	</p>
</Base>

<style>
	.discussion-list {
		list-style: none;
		padding: 0;
		margin: 1.5rem 0;
		display: flex;
		flex-direction: column;
	}

	.discussion-list li {
		padding: 0.9rem 0;
		border-bottom: 1px solid color-mix(in srgb, currentColor 12%, transparent);
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}

	.discussion-list li:first-child {
		border-top: 1px solid color-mix(in srgb, currentColor 12%, transparent);
	}

	.discussion-title {
		font-weight: 600;
		font-size: 1.05rem;
	}

	.discussion-preview {
		margin: 0;
		font-size: 0.9rem;
		opacity: 0.8;
		line-height: 1.4;
	}

	.discussion-meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.85rem;
		opacity: 0.75;
	}

	.dot {
		opacity: 0.6;
	}

	.category-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		padding: 0.1rem 0.55rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--pill-color) 18%, transparent);
		color: var(--pill-color);
		font-weight: 600;
		font-size: 0.75rem;
	}

	.discussion-links {
		display: flex;
		gap: 1.5rem;
	}
</style>
