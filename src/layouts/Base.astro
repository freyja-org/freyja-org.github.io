---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} · Freyja Community</title>
	</head>
	<body>
		<header class="site-header">
			<a href="/" class="brand">Freyja Community Hub</a>
			<nav>
				<a href="/">Home</a>
				<a href="/discussions/">Discussions</a>
				<a href="https://github.com/andersen-lab/Freyja">Freyja on GitHub</a>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer class="site-footer">
			<p>
				Freyja is developed by the <a href="https://github.com/andersen-lab">Andersen Lab</a> at Scripps Research.
			</p>
		</footer>
	</body>
</html>

<style>
	:root {
		color-scheme: light dark;
	}

	body {
		font-family: system-ui, sans-serif;
		margin: 0;
		line-height: 1.5;
	}

	.site-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 1.5rem;
		border-bottom: 1px solid color-mix(in srgb, currentColor 15%, transparent);
	}

	.brand {
		font-weight: 700;
		text-decoration: none;
		color: inherit;
	}

	.site-header nav {
		display: flex;
		gap: 1.25rem;
	}

	.site-header nav a {
		color: inherit;
		text-decoration: none;
	}

	.site-header nav a:hover {
		text-decoration: underline;
	}

	main {
		max-width: 840px;
		margin: 0 auto;
		padding: 2rem 1.5rem 4rem;
	}

	.site-footer {
		padding: 1.5rem;
		text-align: center;
		font-size: 0.9rem;
		opacity: 0.75;
	}
</style>
